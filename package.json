{
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 61902",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 61902",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:check": "vite build --mode development",
    "test:unit": "vitest run",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui",
    "test:smoke:debug": "playwright test --debug",
    "install:browsers": "playwright install chromium",
    "verify": "npm run typecheck && npm run test:unit && npm run build:check",
    "verify:all": "npm run typecheck && npm run test:unit && npm run build:check && npm run test:smoke",
    "verify:ci": "npm run typecheck && npm run test:unit -- --reporter=junit && npm run build:check"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
